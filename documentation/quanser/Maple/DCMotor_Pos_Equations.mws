" 0 "" {MPLTEXT 1 0 27 "G[j1] := 'Theta[1] / I[1]';" }}{PARA 11 "" 1 "
" {XPPMATH 20 "6#>&%\"GG6#%#j1G*&&%&ThetaG6#\"\"\"\"\"\"&%\"IG6#\"\"\"
!\"\"" }}}{EXCHG {PARA 0 "" 0 "" {TEXT 211 75 "Newton's second law of \+
motion (i.e. equation of motion in the time domain):" }}{PARA 0 "> " 0
 "" {MPLTEXT 1 0 97 "NEWTON_EQ_DT := J[eq1] * diff( theta[1](t), t$2 )
 = tq[1]( t ) - B[eq1] * diff( theta[1](t), t );" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#>%-NEWTON_EQ_DTG/*&&%\"JG6#%$eq1G\"\"\"-%%diffG6$-&%&th
etaG6#\"\"\"6#%\"tG-%\"$G6$%\"tG\"\"#\"\"\",&-&%#tqG6#\"\"\"6#%\"tG\"
\"\"*&&%\"BG6#%$eq1G\"\"\"-%%diffG6$-&%&thetaG6#\"\"\"6#%\"tG%\"tG\"\"
\"!\"\"" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 45 "NEWTON_EQ_S := l
aplace( NEWTON_EQ_DT, t, s );" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%,NE
WTON_EQ_SG/*&&%\"JG6#%$eq1G\"\"\",&*&%\"sG\"\"\",&*&%\"sG\"\"\"&%&Thet
aG6#\"\"\"\"\"\"\"\"\"-&%&thetaG6#\"\"\"6#\"\"!!\"\"\"\"\"\"\"\"--%\"D
