iff(L,q[i]) = Q[i];" "6#/,&-%%DiffG6$-F&6$%\"LG&%%qdotG6#%\"iG%\"tG\"
\"\"-F&6$F*&%\"qGF-!\"\"&%\"QGF-" }{TEXT 240 6 "  for " }{XPPEDIT 18 
0 "i = 1" "6#/%\"iG\"\"\"" }{TEXT 240 9 " through " }{XPPEDIT 18 0 "N;
" "6#%\"NG" }}{PARA 215 "" 0 "" {TEXT 240 6 "where:" }}{PARA 215 "" 0 
"" {TEXT 240 1 " " }{XPPEDIT 18 0 "Q[i]" "6#&%\"QG6#%\"iG" }{TEXT 240 
62 "'s are special combinations of external forces and called the " }
{TEXT 241 19 "generalized forces," }}{PARA 215 "" 0 "" {TEXT 241 1 " "
 }{XPPEDIT 18 0 "q[1]" "6#&%\"qG6#\"\"\"" }{TEXT 240 7 ", ..., " }
{XPPEDIT 18 0 "q[N];" "6#&%\"qG6#%\"NG" }{TEXT 240 6 ", are " }{TEXT 
241 2 "N " }{TEXT 240 69 "independent coordinates chosen to describe t
he system and called the " }{TEXT 241 23 "generalized coordinates" }
{TEXT 240 1 "," }}{PARA 215 "" 0 "" {TEXT 240 5 " and " }{XPPEDIT 18 
0 "L;" "6#%\"LG" }{TEXT 240 8 " is the " }{TEXT 241 10 "Lagrangian" }
{TEXT 240 15 " of the system." }}{PARA 215 "" 0 "" {XPPEDIT 18 0 "L" "
6#%\"LG" }{TEXT 240 15 " is defined by:" }}{PARA 217 "" 0 "" {XPPEDIT 
18 0 "L = T - U" "6#/%\"LG,&%\"TG\"\"\"%\"UG!\"\"" }}{PARA 215 "" 0 ""
